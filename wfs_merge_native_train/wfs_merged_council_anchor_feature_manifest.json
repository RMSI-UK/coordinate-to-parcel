{
  "name": "wfs_merged_council_anchor_group_model_v1",
  "dataset": {
    "label_gpkg": "/data/sheffield/spatial/base-map/sheffield_wfs_merged_council_train_parcel.gpkg",
    "label_layer": "train_parcel_label",
    "input_gpkg": "/data/sheffield/spatial/base-map/sheffield_wfs_merged_council_train_molecular_depth3.gpkg",
    "input_layer": "train_input_molecular_depth3"
  },
